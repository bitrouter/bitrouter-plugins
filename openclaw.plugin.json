{
  "id": "bitrouter",
  "name": "OpenClaw BitRouter Plugin",
  "version": "0.1.0",
  "description": "Route LLM requests through BitRouter — a local multi-provider proxy with failover, load balancing, and unified API key management.",
  "entry": "dist/index.js",
  "skills": ["skills/bitrouter"],
  "configSchema": {
    "type": "object",
    "properties": {
      "port": {
        "type": "number",
        "default": 8787,
        "description": "Port for BitRouter to listen on."
      },
      "host": {
        "type": "string",
        "default": "127.0.0.1",
        "description": "Host address for BitRouter to bind to."
      },
      "autoStart": {
        "type": "boolean",
        "default": true,
        "description": "Automatically start BitRouter daemon when OpenClaw starts."
      },
      "healthCheckIntervalMs": {
        "type": "number",
        "default": 30000,
        "description": "Interval in ms between health check polls."
      },
      "interceptAllModels": {
        "type": "boolean",
        "default": false,
        "description": "When true, route ALL model requests through BitRouter. When false (default), only intercept models that BitRouter has configured routes for."
      },
      "providers": {
        "type": "object",
        "description": "Provider configurations. Keys are provider names (e.g. 'openai', 'anthropic'). Values configure API keys, base URLs, and inheritance.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string",
              "description": "API key or env var reference like '${OPENAI_API_KEY}'."
            },
            "apiBase": {
              "type": "string",
              "description": "Custom API base URL."
            },
            "envPrefix": {
              "type": "string",
              "description": "Env var prefix for auto-loading keys (e.g. 'OPENAI')."
            },
            "derives": {
              "type": "string",
              "description": "Inherit defaults from a built-in provider (e.g. 'openai')."
            }
          }
        }
      },
      "guardrails": {
        "type": "object",
        "description": "Content guardrail configuration. Scans outbound/inbound traffic for sensitive patterns.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Master switch for guardrails."
          },
          "disabledPatterns": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Built-in patterns to disable (e.g. 'ip_addresses')."
          },
          "upgoing": {
            "type": "object",
            "additionalProperties": { "type": "string", "enum": ["warn", "redact", "block"] },
            "description": "Per-pattern action for outbound traffic (user → LLM)."
          },
          "downgoing": {
            "type": "object",
            "additionalProperties": { "type": "string", "enum": ["warn", "redact", "block"] },
            "description": "Per-pattern action for inbound traffic (LLM → user)."
          },
          "customPatterns": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "regex": { "type": "string" },
                "direction": { "type": "string", "enum": ["upgoing", "downgoing", "both"], "default": "upgoing" }
              },
              "required": ["name", "regex"]
            },
            "description": "User-defined regex patterns."
          }
        }
      },
      "models": {
        "type": "object",
        "description": "Model routing definitions. Keys are virtual model names. Values define routing strategy and endpoint lists.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["priority", "load_balance"],
              "default": "priority",
              "description": "'priority' tries endpoints in order with failover. 'load_balance' distributes via round-robin."
            },
            "endpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "provider": {
                    "type": "string",
                    "description": "Provider name (must be configured in providers section or a built-in)."
                  },
                  "modelId": {
                    "type": "string",
                    "description": "Upstream model ID to send to this provider."
                  },
                  "apiKey": {
                    "type": "string",
                    "description": "Optional per-endpoint API key override."
                  },
                  "apiBase": {
                    "type": "string",
                    "description": "Optional per-endpoint API base URL override."
                  }
                },
                "required": ["provider", "modelId"]
              }
            }
          },
          "required": ["endpoints"]
        }
      },
      "solanaRpcUrl": {
        "type": "string",
        "description": "Solana RPC URL for on-chain operations (Swig wallet, x402 payments)."
      },
      "cloud": {
        "type": "object",
        "description": "Cloud-specific configuration for BitRouter Cloud mode.",
        "properties": {
          "solanaRpcUrl": {
            "type": "string",
            "description": "Solana RPC URL override for cloud mode."
          }
        }
      },
      "a2aAgents": {
        "type": "array",
        "description": "Upstream A2A agents to proxy through BitRouter's A2A gateway.",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Agent name (used in URL path: /a2a/{name})."
            },
            "url": {
              "type": "string",
              "description": "Upstream agent URL."
            },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "Custom headers to send to the upstream agent."
            },
            "cardPath": {
              "type": "string",
              "description": "Optional local path to cache the agent card."
            }
          },
          "required": ["name", "url"]
        }
      },
      "a2aAgentPricing": {
        "type": "object",
        "description": "Per-agent pricing overrides for A2A agents.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "defaultCostPerCall": { "type": "number", "description": "Default cost per method call." },
            "overrides": {
              "type": "object",
              "additionalProperties": { "type": "number" },
              "description": "Per-method cost overrides (e.g. 'message/send': 0.002)."
            }
          }
        }
      },
      "mcpServers": {
        "type": "array",
        "description": "Upstream MCP servers to proxy through BitRouter's MCP gateway.",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Server name (used for grouping and identification)."
            },
            "command": {
              "type": "string",
              "description": "Command to spawn the MCP server (e.g. 'npx')."
            },
            "args": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Arguments for the server command."
            },
            "toolFilter": {
              "type": "object",
              "properties": {
                "allow": { "type": "array", "items": { "type": "string" } },
                "deny": { "type": "array", "items": { "type": "string" } }
              },
              "description": "Allow/deny list for tool names."
            },
            "paramRestrictions": {
              "type": "object",
              "properties": {
                "rules": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "tool": { "type": "string" },
                      "forbiddenParams": { "type": "array", "items": { "type": "string" } }
                    },
                    "required": ["tool"]
                  }
                }
              },
              "description": "Per-tool parameter restrictions."
            }
          },
          "required": ["name", "command"]
        }
      },
      "mcpGroups": {
        "type": "object",
        "description": "Named groups of MCP servers for access control.",
        "additionalProperties": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "mcpServerPricing": {
        "type": "object",
        "description": "Per-server pricing overrides for MCP tools.",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "defaultCostPerCall": { "type": "number", "description": "Default cost per tool call." },
            "overrides": {
              "type": "object",
              "additionalProperties": { "type": "number" },
              "description": "Per-tool cost overrides."
            }
          }
        }
      },
      "skills": {
        "type": "array",
        "description": "Skills to register with BitRouter's skills registry on startup.",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "Skill name." },
            "description": { "type": "string", "description": "Skill description." },
            "source": { "type": "string", "description": "Optional source URL." },
            "requiredApis": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "provider": { "type": "string" }
                },
                "required": ["provider"]
              },
              "description": "APIs required by this skill."
            }
          },
          "required": ["name", "description"]
        }
      },
      "mode": {
        "type": "string",
        "enum": ["byok", "cloud", "auto"],
        "description": "Setup mode. 'auto' = detected from environment variables. 'byok' = bring your own API key (wizard). 'cloud' = Swig wallet for x402 payments. Unset = not yet configured and no env vars found."
      },
      "byok": {
        "type": "object",
        "description": "BYOK upstream provider configuration. Set automatically by the setup wizard.",
        "properties": {
          "upstreamProvider": {
            "type": "string",
            "description": "Upstream provider id (e.g. 'openrouter', 'openai', 'anthropic', or 'other')."
          },
          "apiBase": {
            "type": "string",
            "description": "Custom API base URL. Defaults to the provider's public URL."
          }
        },
        "required": ["upstreamProvider"]
      }
    }
  },
  "providerAuthEnvVars": [
    "BITROUTER_API_KEY",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "OPENROUTER_API_KEY"
  ],
  "providerAuthChoices": [
    {
      "id": "byok",
      "label": "BYOK — bring your own API key",
      "hint": "Route through OpenRouter, OpenAI, Anthropic, or any compatible API",
      "cliFlag": "--bitrouter-api-key"
    },
    {
      "id": "cloud",
      "label": "BitRouter Cloud (wallet setup)",
      "hint": "Set up Swig wallet for x402 payments via interactive CLI"
    }
  ],
  "uiHints": {
    "icon": "router",
    "category": "infrastructure",
    "mode": {
      "label": "Setup Mode",
      "help": "Set by the first-run wizard. Run: openclaw models auth login --provider bitrouter"
    },
    "byok": {
      "label": "BYOK Provider Config",
      "help": "Upstream provider settings configured via the BYOK wizard."
    },
    "byok.upstreamProvider": {
      "label": "Upstream Provider"
    },
    "byok.apiBase": {
      "label": "Custom API Base URL",
      "placeholder": "https://openrouter.ai/api/v1"
    }
  }
}
