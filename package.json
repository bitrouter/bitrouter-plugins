{
  "name": "@bitrouter/openclaw-plugin",
  "version": "0.3.0",
  "description": "BitRouter integration for OpenClaw — transparent LLM routing with failover, load balancing, and multi-provider support.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "skills/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp -r skills dist/ && cp openclaw.plugin.json dist/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "openclaw": "^2026.3.13",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "openclaw": {
    "id": "bitrouter",
    "extensions": [
      "./dist/index.js"
    ]
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitrouter/bitrouter-openclaw.git"
  },
  "keywords": [
    "openclaw",
    "bitrouter",
    "llm",
    "proxy",
    "routing",
    "openai",
    "anthropic",
    "google"
  ]
}
